# universal-video-generator 环境变量（复制本文件为 .env 后填写）
#
# ★★★ 即开即用最少只需这两个（live-server.js / 双击 start-video-factory.bat 用）★★★
# 1) 视频出片（快子·丽帧 Seedance 2.0）——平台后台领取的 kz- 开头 key：
KUAIZI_API_KEY=
# 2) 免描述自动写脚本 + 文生图（hfsy 网关，sk- 开头 key）——不填则需自己写描述：
IMAGE_API_KEY=
# 可选：覆盖默认地址 / 端口
# KUAIZI_BASE_URL=https://aiopenapi.kuaizi.cn
# IMAGE_BASE_URL=https://www.hfsyapi.cn
# WEB_PORT=8088
# LLM_MODEL=gpt-5.5
#
# ── 以下为完整 TS 引擎（server.ts/CLI）才用到的可选项；只用 live-server 可忽略 ──
# ── 视频模型 ──
KLING_API_KEY=
KLING_BASE_URL=
RUNWAY_API_KEY=
RUNWAY_BASE_URL=
SEEDANCE_API_KEY=
SEEDANCE_BASE_URL=
VEO_API_KEY=
VEO_BASE_URL=
# ── TTS / 声纹克隆 ──
ELEVENLABS_API_KEY=
VOLCENGINE_TOKEN=
COSYVOICE_BASE_URL=http://localhost:9880
COSYVOICE_ENABLED=false
GPTSOVITS_BASE_URL=http://localhost:9872
GPTSOVITS_ENABLED=false
# 本地开源 TTS（无云 API，零成本，CPU 可跑）——主选 MOSS-TTS-Nano；备选 kokoro/piper
LOCAL_TTS_ENABLED=false
LOCAL_TTS_BASE_URL=http://localhost:9881
LOCAL_TTS_MODEL=moss
# ── 运行时 ──
UVG_CONCURRENCY=4
UVG_LOG_LEVEL=info
UVG_INCLUDE_SKELETONS=true
FFMPEG_BIN=ffmpeg
PORT=8787
# ── 商用：多租户鉴权 / 持久化 / 存储 ──
# 多租户：JSON 数组（生产建议用控制台/DB 下发）
UVG_TENANTS=[{"id":"acme","name":"Acme","apiKey":"sk_live_xxx","quota":{"maxConcurrent":8,"dailyMax":5000,"dailyCostCapUsd":500}}]
# 开发便捷：追加一个 dev 租户
UVG_DEV_KEY=sk_dev_local
# 任务/产物持久化路径
UVG_JOBS_FILE=./.uvg-jobs.json
UVG_STORAGE_DIR=./.uvg-artifacts
