# VIDEO-FACTORY 环境变量模板
# 复制为 .env 后填入真实Key
# 使用方式: cp .env.example .env && nano .env

# ===== 视频生成 =====
KUAIZI_API_KEY=kz-your-key-here          # 丽帧/快子（主力视频）
AGNES_API_KEY=sk-your-key-here           # Agnes（视频兜底）
VIDEO_BACKEND=kuaizi                     # kuaizi(丽帧) | agnes(兜底)

# ===== AI文本/看图 =====
IMAGE_API_KEY=sk-your-key-here           # hfsy网关（看图+文生图）
DEEPSEEK_API_KEY=sk-your-key-here        # DeepSeek（文本主力）
DEEPSEEK_MODEL=deepseek-v4-pro           # deepseek-v4-pro | deepseek-v4-flash
KIMI_API_KEY=sk-your-key-here            # Kimi（文本兜底，可选）

# ===== 图片模型优先级 =====
# 逗号分隔，按优先级降序排列：gpt-image-2 > sd-2-vip > sd-2-vip-720
IMAGE_MODELS=gpt-image-2,sd-2-vip,sd-2-vip-720

# ===== 超时设置 =====
HTTP_TIMEOUT_MS=120000                   # 图片生成超时（必须>=90s，建议120000ms）

# ===== 自进化/遥测 =====
UVG_TELEMETRY=off                        # on | off（默认关，opt-in隐私优先）
UVG_TELEMETRY_URL=http://localhost:8089/telemetry
UVG_PARAMS_URL=http://localhost:8089/params/latest

# ===== 总部管理 =====
UVG_HQ_ADMIN_KEY=your-admin-key-here     # HQ管理端鉴权密钥（生产环境务必修改）

# ===== 本地TTS =====
TTS_ENDPOINT=http://localhost:5000       # 本地TTS服务地址（语音锁定模块依赖）

# ===== 蜂群配置 =====
SWARM_AGENT_COUNT=300                    # Agent总数（最大并发工作单元）
SWARM_HQ_URL=http://localhost:8089       # HQ地址（总部收集器端点）
SWARM_HEARTBEAT_INTERVAL=30000           # 心跳间隔(ms) - 30秒
SWARM_PARAMS_SYNC_INTERVAL=300000        # 参数同步间隔(ms) - 5分钟
